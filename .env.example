# Vercel + Supabase integration variables (recommended)
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# (Optional) If you are not using the Vercel integration, you can map these to DATABASE_URL/DIRECT_URL
# by exporting POSTGRES_PRISMA_URL and POSTGRES_URL_NON_POOLING instead.
DEMO_AUTH_SECRET="cambia-este-valor"
OPENAI_API_KEY="pon-tu-key-aqui"
OPENAI_MODEL="gpt-4o"
OPENAI_MODEL_FALLBACK="gpt-4o-mini"
OPENAI_TEMPERATURE="0.1"
OPENAI_MAX_TOKENS="900"
OPENAI_TRANSCRIBE_MODEL="whisper-1"
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="pon-service-role-key-aqui"
SUPABASE_EVIDENCE_BUCKET="evidences"
